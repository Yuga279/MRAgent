# Deepgram mode (premium voice quality). Optional: without it /ws, /ws-agent
# and /api/tts are disabled but the free browser mode still works.
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Browser (free) mode — LLM for the support agent. Add one or both;
# the Settings panel in the app picks which one to use.
GROQ_API_KEY=
GEMINI_API_KEY=

# Pinecone vector database — knowledge base + long-term conversational
# memory. After setting the key, run `npm run ingest-knowledge` to (re)index
# data/knowledge.md.
PINECONE_API_KEY=
# PINECONE_INDEX=mragent-knowledge

# MongoDB (required for the support agent). Orders + product catalog live in
# the `orders`/`products` collections, per-customer profiles in
# `customer_memory`, and /api/chat keeps conversational memory as LangGraph
# checkpoints per browser session.
MONGODB_URI=
# MONGODB_DB=mragent
