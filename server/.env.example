# Deepgram mode (premium voice quality)
DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Browser (free) mode — LLM for the support agent. Add one or both;
# the Settings panel in the app picks which one to use.
GROQ_API_KEY=
GEMINI_API_KEY=

# Pinecone vector database for the knowledge base (optional). When set, the
# agent retrieves knowledge via semantic search (search_knowledge function)
# instead of inlining data/knowledge.md into the prompt. After setting the
# key, run `npm run ingest-knowledge` to (re)index knowledge.md.
PINECONE_API_KEY=
# PINECONE_INDEX=mragent-knowledge
